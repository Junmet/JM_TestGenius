# ========== 模型提供方 ==========
# deepseek（默认）| qwen（通义千问，阿里云 DashScope OpenAI 兼容接口）
# LLM_PROVIDER=deepseek

# ========== 通用（可选，覆盖下方各厂商专用变量）==========
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
# LLM_TIMEOUT=120
# LLM_MAX_TOKENS=16384

# ========== DeepSeek（LLM_PROVIDER=deepseek 或未设置时）==========
DEEPSEEK_API_KEY=your_key_here
# 可选。OpenAI 兼容 base（不要以 /v1 结尾也可，脚本会兼容）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选。常见：deepseek-chat / deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# ========== 通义千问（LLM_PROVIDER=qwen）==========
# 在阿里云 DashScope 控制台创建 API Key：https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=your_dashscope_key
# 可选。默认已为兼容模式地址，一般无需改
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
# 可选：qwen-plus / qwen-turbo / qwen-max 等（以控制台开通为准）
# QWEN_MODEL=qwen-plus

# ========== 其它 ==========
# 可选：输出默认语言（zh/en）
APP_LANGUAGE=zh
