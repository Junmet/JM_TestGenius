# ========== 模型提供方 ==========
# deepseek（默认）| qwen（通义千问，阿里云 DashScope OpenAI 兼容接口）
# LLM_PROVIDER=deepseek

# ========== 通用（可选，覆盖下方各厂商专用变量）==========
# LLM_API_KEY=
# LLM_BASE_URL=
# LLM_MODEL=
# LLM_TIMEOUT=120
# LLM_MAX_TOKENS=16384

# ========== DeepSeek（LLM_PROVIDER=deepseek 或未设置时）==========
DEEPSEEK_API_KEY=your_key_here
# 可选。OpenAI 兼容 base（不要以 /v1 结尾也可，脚本会兼容）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 可选。常见：deepseek-chat / deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# ========== 通义千问（LLM_PROVIDER=qwen）==========
# 在阿里云 DashScope 控制台创建 API Key：https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=your_dashscope_key
# 可选。默认已为兼容模式地址，一般无需改
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
# 可选：qwen-plus / qwen-turbo / qwen-max 等（以控制台开通为准）
# QWEN_MODEL=qwen-plus

# ========== 其它 ==========
# 可选：输出默认语言（zh/en）
APP_LANGUAGE=zh

# ========== 日志与排障（可选）==========
# 设为 1 / true / yes / on 时，在 log/ 中记录每次 LLM 调用的请求与响应摘要
# （仅各消息的长度与截断预览，不含 API Key；正文中的 sk-xxx 等形态会被遮蔽）
# 关闭则不要设置，或设为 0。命令行 `--llm-log-io` 会覆盖为「本次强制开启」。
# LLM_LOG_IO=0

# ========== 远程需求：Confluence / 飞书（可选，仅在使用 URL 拉取时）==========
# Atlassian Confluence Cloud：页面 REST API
# CONFLUENCE_BASE_URL=https://your-domain.atlassian.net
# CONFLUENCE_EMAIL=your@email.com
# CONFLUENCE_API_TOKEN=（在 Atlassian 账户安全里创建 API Token）
# 亦可用 CONFLUENCE_PAT= 代替 CONFLUENCE_API_TOKEN
#
# 飞书开放平台应用（Wiki get_node + docx raw_content，需在后台勾选知识库与云文档读权限）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# 可选：用户 user_access_token（仅本人可见文档、或不便「添加文档应用」时用）
# FEISHU_USER_ACCESS_TOKEN=
